{
  "name": "bid_full_fill",
  "description": "BID order at 100 with phantom=10, sell trade of 20 fills all 5 lots",
  "initial_levels": [
    {"bid_px": 100, "bid_sz": 10, "ask_px": 102, "ask_sz": 40}
  ],
  "events": [
    {
      "type": "submit_order",
      "order": {"side": "Bid", "price": 100, "size": 5, "client_oid": "BID_1", "order_type": "LIMIT", "tif": "GTC"},
      "expected_reports": [
        {"exec_type": "NEW", "order_status": "NEW", "client_oid": "BID_1", "leaves_qty": 5}
      ]
    },
    {
      "type": "trade",
      "side": "Ask", "price": 100, "size": 20,
      "expected_reports": [
        {"exec_type": "FILL", "order_status": "FILLED", "client_oid": "BID_1", "filled_qty": 5, "leaves_qty": 0}
      ]
    }
  ]
}
